{
  "version": 2,
  "builds": [
    {
      "src": "dist/**",
      "use": "@vercel/static"
    },
    {
      "src": "staff.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/dist/index.html"
    },
    {
      "src": "/menu",
      "dest": "/dist/index.html"
    },
    {
      "src": "/staff",
      "dest": "/staff.html"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/dist/assets/$1"
    },
    {
      "src": "/food-images/(.*)",
      "dest": "/dist/food-images/$1"
    },
    {
      "src": "/logo.png",
      "dest": "/dist/logo.png"
    }
  ]
}
